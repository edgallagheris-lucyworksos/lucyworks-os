    "staff.displayName": "staffName",
    "staff.role": "role",
    "staff.active": "active",
    "staff.skills": "skills",
    "shift.id": "shiftRef",
    "shift.startsAt": "startsAt",
    "shift.endsAt": "endsAt",
    "shift.department": "department",
    "shift.status": "status",
    "absence.type": "absenceType",
