# Database
# Local development only:
DATABASE_URL=sqlite:///./lucyworks.db
AUTO_CREATE_SCHEMA=true
DATABASE_ECHO=false

# Authentication policy
# local = signed development tokens; oidc = hospital identity provider.
AUTH_MODE=local
AUTH_ENFORCEMENT=required
AUTH_AUDIENCE=lucyworks-api
AUTH_ISSUER=lucyworks-local
AUTH_TOKEN_MINUTES=60
AUTH_CLOCK_SKEW_SECONDS=30

# Local development only. Disable in every shared or production deployment.
AUTH_DEV_LOGIN_ENABLED=true
AUTH_JWT_SECRET=replace-with-at-least-32-random-bytes

# Production PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://lucyworks:password@db-host:5432/lucyworks
# AUTO_CREATE_SCHEMA=false

# Production OIDC example:
# AUTH_MODE=oidc
# AUTH_ENFORCEMENT=required
# AUTH_AUDIENCE=lucyworks-api
# OIDC_ISSUER=https://identity.example.org/
# OIDC_JWKS_URL=https://identity.example.org/.well-known/jwks.json
# OIDC_AUTHORIZATION_URL=https://identity.example.org/authorize
# OIDC_TOKEN_URL=https://identity.example.org/oauth/token
# OIDC_CLIENT_ID=lucyworks-web
# OIDC_CLIENT_SECRET=
# OIDC_SCOPE=openid profile email
# OIDC_ALGORITHMS=RS256
# OIDC_ROLE_CLAIM=roles
# AUTH_ROLE_MAP={"Hospital Operations Manager":"ops_manager","Clinical Director":"clinical_director","Veterinary Surgeon":"clinician","Registered Veterinary Nurse":"nurse","Hospital Administrator":"admin"}

# Hospital operating-system policy
# These are evidence references or deployed policy identifiers, not free text.
# BACKUP_POLICY_REF=policy://lucyworks/database-backup/v1
# DATABASE_BACKUP_ENABLED=true
# DATA_RETENTION_POLICY_REF=policy://lucyworks/data-retention/v1
# INCIDENT_RESPONSE_PLAN_REF=policy://lucyworks/incident-response/v1
# ERROR_REPORTING_DSN=secret-managed-monitoring-dsn
# ALLOW_LEGACY_BOARD_BULK_REPLACE=false

# External integrations
# Each IntegrationConnection stores only the environment-variable name in
# secret_env. The secret value remains in deployment secrets and signs:
#   HMAC-SHA256(timestamp + "." + raw_request_body)
# Required headers:
#   X-LucyWorks-Timestamp: Unix timestamp
#   X-LucyWorks-Signature: sha256=<hex digest>
# PIMS_WEBHOOK_SECRET=replace-with-random-signing-secret
# IMAGING_WEBHOOK_SECRET=replace-with-random-signing-secret
# LAB_WEBHOOK_SECRET=replace-with-random-signing-secret
# HR_WEBHOOK_SECRET=replace-with-random-signing-secret

# Never set this outside the named CI legacy fixtures:
# LUCYWORKS_LEGACY_TEST_BYPASS=false
